# Copy to .env.local for local dev, and set the same two vars in Vercel.
# The anon key is a public client key (safe to ship in the browser); row-level
# security in Supabase is what actually protects your data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
